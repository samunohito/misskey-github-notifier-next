{
  "name": "misskey-github-notifier-next",
  "version": "1.0.0",
  "description": "A GitHub notification service for Misskey",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy src/index.ts",
    "lint": "bun run lint:typecheck && bun run lint:biome",
    "lint:typecheck": "tsc --noEmit --project tsconfig-typecheck.json",
    "lint:biome": "biome lint ./src",
    "format": "biome check --write ./src",
    "test": "vitest run"
  },
  "author": "samunohito",
  "license": "MIT",
  "dependencies": {
    "hono": "4.11.3",
    "neverthrow": "8.2.0",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@cloudflare/workers-types": "4.20260109.0",
    "@octokit/webhooks": "14.2.0",
    "@types/node": "22.19.5",
    "bun": "1.3.5",
    "vite-tsconfig-paths": "6.0.4",
    "vitest": "4.0.16",
    "wrangler": "4.58.0"
  }
}
